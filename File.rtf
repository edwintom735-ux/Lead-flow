\fs24 \
\

\fs20 <div style="text-align:center;padding:16px 0 32px">
\fs24 \

\fs20 <button class="run-btn" onclick="resetAll()">Run another campaign</button>
\fs24 \

\fs20 </div>
\fs24 \

\fs20 </div>
\fs24 \
\

\fs20 <script>
\fs24 \

\fs20 const sleep=ms=>new Promise(r=>setTimeout(r,ms));
\fs24 \
\

\fs20 function setDot(n,s)\{
\fs24 \

\fs20 const d=document.getElementById('d'+n);
\fs24 \

\fs20 d.className='pdot '+s;
\fs24 \

\fs20 if(s==='running')d.innerHTML='<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:spin2 .7s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>';
\fs24 \

\fs20 else if(s==='done')d.innerHTML='\uc0\u10003 ';
\fs24 \

\fs20 else d.innerHTML=n;
\fs24 \

\fs20 \}
\fs24 \

\fs20 function setSub(n,t)\{document.getElementById('s'+n).textContent=t\}
\fs24 \

\fs20 function showDetail(id,txt,cls)\{const e=document.getElementById(id);e.textContent=txt;e.className='pdetail show'+(cls?' '+cls:'');\}
\fs24 \
\

\fs20 async function callClaude(prompt)\{
\fs24 \

\fs20 const r=await fetch("{\field{\*\fldinst{HYPERLINK "https://api.anthropic.com/v1/messages"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 https://api.anthropic.com/v1/messages}}",\{method:"POST",headers:\{"Content-Type":"application/json"\},body:JSON.stringify(\{model:"claude-sonnet-4-20250514",max_tokens:1200,system:"You are a B2B sales AI. Respond ONLY with valid JSON. No markdown, no backticks.",messages:[\{role:"user",content:prompt\}]\})\});
\fs24 \

\fs20 const d=await r.json();
\fs24 \

\fs20 const t=d.content?.find(b=>b.type==="text")?.text||"[]";
\fs24 \

\fs20 return JSON.parse(t.replace(/```json|```/g,'').trim());
\fs24 \

\fs20 \}
\fs24 \
\

\fs20 async function callGmail(prompt)\{
\fs24 \

\fs20 await fetch("{\field{\*\fldinst{HYPERLINK "https://api.anthropic.com/v1/messages"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 https://api.anthropic.com/v1/messages}}",\{method:"POST",headers:\{"Content-Type":"application/json"\},body:JSON.stringify(\{model:"claude-sonnet-4-20250514",max_tokens:800,mcp_servers:[\{type:"url",url:"{\field{\*\fldinst{HYPERLINK "https://gmail.mcp.claude.com/mcp"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 https://gmail.mcp.claude.com/mcp}}",name:"gmail"\}],messages:[\{role:"user",content:prompt\}]\})\});
\fs24 \

\fs20 \}
\fs24 \
\

\fs20 async function callCalendar(prompt)\{
\fs24 \

\fs20 await fetch("{\field{\*\fldinst{HYPERLINK "https://api.anthropic.com/v1/messages"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 https://api.anthropic.com/v1/messages}}",\{method:"POST",headers:\{"Content-Type":"application/json"\},body:JSON.stringify(\{model:"claude-sonnet-4-20250514",max_tokens:800,mcp_servers:[\{type:"url",url:"{\field{\*\fldinst{HYPERLINK "https://gcal.mcp.claude.com/mcp"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 https://gcal.mcp.claude.com/mcp}}",name:"gcal"\}],messages:[\{role:"user",content:prompt\}]\})\});
\fs24 \

\fs20 \}
\fs24 \
\

\fs20 function renderCalendar(bookedLeads)\{
\fs24 \

\fs20 const now=new Date();
\fs24 \

\fs20 const yr=now.getFullYear(),mo=now.getMonth();
\fs24 \

\fs20 const months=["January","February","March","April","May","June","July","August","September","October","November","December"];
\fs24 \

\fs20 document.getElementById('cal-badge').textContent=months[mo]+' '+yr;
\fs24 \

\fs20 const days=["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];
\fs24 \

\fs20 let html=days.map(d=>`<div class="ch">$\{d\}</div>`).join('');
\fs24 \

\fs20 let fd=new Date(yr,mo,1).getDay();fd=fd===0?6:fd-1;
\fs24 \

\fs20 const dim=new Date(yr,mo+1,0).getDate();
\fs24 \

\fs20 const td=now.getDate();
\fs24 \

\fs20 const bookedDays=bookedLeads.map(l=>l.day);
\fs24 \

\fs20 for(let i=0;i<fd;i++)html+=`<div class="cd"></div>`;
\fs24 \

\fs20 for(let d=1;d<=dim;d++)\{
\fs24 \

\fs20 const idx=bookedDays.indexOf(d);
\fs24 \

\fs20 const isB=idx>=0;
\fs24 \

\fs20 const isT=d===td;
\fs24 \

\fs20 let cls='cd real'+(isT?' today':'')+(isB?' booked':'');
\fs24 \

\fs20 let evt=isB?`<div class="ce">$\{bookedLeads[idx].first\} \'b7 $\{bookedLeads[idx].time\}</div>`:'';
\fs24 \

\fs20 html+=`<div class="$\{cls\}"><div class="dn">$\{d\}</div>$\{evt\}</div>`;
\fs24 \

\fs20 \}
\fs24 \

\fs20 document.getElementById('cal-grid').innerHTML=html;
\fs24 \

\fs20 \}
\fs24 \
\

\fs20 const avColors=['a','b','c'];
\fs24 \
\

\fs20 async function runPipeline()\{
\fs24 \

\fs20 const senderName=document.getElementById('senderName').value||'Alex';
\fs24 \

\fs20 const senderCo=document.getElementById('senderCo').value||'LeadFlow';
\fs24 \

\fs20 const industry=document.getElementById('industry').value||'SaaS';
\fs24 \

\fs20 const jobtitle=document.getElementById('jobtitle').value||'Head of Operations';
\fs24 \

\fs20 const size=document.getElementById('size').value;
\fs24 \

\fs20 const duration=document.getElementById('duration').value;
\fs24 \

\fs20 const pain=document.getElementById('pain').value||'manual inefficiencies';
\fs24 \
\

\fs20 document.getElementById('runBtn').disabled=true;
\fs24 \

\fs20 document.getElementById('pipeline-section').style.display='block';
\fs24 \

\fs20 document.getElementById('results-section').style.display='none';
\fs24 \

\fs20 document.getElementById('pipeline-section').scrollIntoView(\{behavior:'smooth',block:'start'\});
\fs24 \
\

\fs20 await sleep(300);
\fs24 \
\

\fs20 setDot(1,'running');setSub(1,`Scanning $\{industry\} companies for $\{jobtitle\}...`);
\fs24 \

\fs20 await sleep(1200);
\fs24 \
\

\fs20 let leads=[];
\fs24 \

\fs20 try\{
\fs24 \

\fs20 leads=await callClaude(`Generate 3 realistic B2B leads. Industry: "$\{industry\}", size: "$\{size\}", title: "$\{jobtitle\}". Return JSON array, each: \{id,name,title,company,email,score(75-97)\}`);
\fs24 \

\fs20 \}catch(e)\{
\fs24 \

\fs20 leads=[
\fs24 \

\fs20 \{id:1,name:"Sarah Chen",title:jobtitle,company:"Nexus Tech",email:"{\field{\*\fldinst{HYPERLINK "mailto:s.chen@nexustech.io"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 s.chen@nexustech.io}}",score:94\},
\fs24 \

\fs20 \{id:2,name:"Marcus Webb",title:jobtitle,company:"Orbita Group",email:"{\field{\*\fldinst{HYPERLINK "mailto:m.webb@orbita.com"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 m.webb@orbita.com}}",score:87\},
\fs24 \

\fs20 \{id:3,name:"Priya Nair",title:jobtitle,company:"Stackflow Ltd",email:"{\field{\*\fldinst{HYPERLINK "mailto:p.nair@stackflow.co"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 p.nair@stackflow.co}}",score:81\}
\fs24 \

\fs20 ];
\fs24 \

\fs20 \}
\fs24 \

\fs20 setDot(1,'done');setSub(1,`$\{leads.length\} leads found`);
\fs24 \

\fs20 showDetail('e1',leads.map(l=>`$\{{\field{\*\fldinst{HYPERLINK "http://l.name/"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 l.name}}\} \'b7 $\{l.company\}`).join('\\n'));
\fs24 \

\fs20 await sleep(400);
\fs24 \
\

\fs20 setDot(2,'running');setSub(2,'Scoring each lead by fit...');
\fs24 \

\fs20 await sleep(1400);
\fs24 \

\fs20 leads.sort((a,b)=>b.score-a.score);
\fs24 \

\fs20 setDot(2,'done');setSub(2,'Top leads selected');
\fs24 \

\fs20 showDetail('e2',leads.map(l=>`$\{{\field{\*\fldinst{HYPERLINK "http://l.name/"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 l.name}}\} ($\{l.company\}) \'97 $\{l.score\}/100`).join('\\n'));
\fs24 \

\fs20 await sleep(400);
\fs24 \
\

\fs20 setDot(3,'running');setSub(3,'Drafting personalised emails...');
\fs24 \

\fs20 let emailText='';
\fs24 \

\fs20 try\{
\fs24 \

\fs20 const draft=await callClaude(`Write a short cold email from $\{senderName\} at $\{senderCo\} to $\{leads[0].name\}, $\{leads[0].title\} at $\{leads[0].company\}. Pain: "$\{pain\}". Ask for $\{duration\}-min call. Under 80 words. Return JSON: \{subject,body\}`);
\fs24 \

\fs20 emailText=`To: $\{leads[0].email\}\\nSubject: $\{draft.subject\}\\n\\n$\{draft.body\}`;
\fs24 \

\fs20 await callGmail(`Send email to $\{leads[0].email\}: Subject "$\{draft.subject\}" Body: $\{draft.body\}`);
\fs24 \

\fs20 \}catch(e)\{
\fs24 \

\fs20 emailText=`To: $\{leads[0].email\}\\nSubject: Quick question for $\{leads[0].company\}\\n\\nHi $\{leads[0].name.split(' ')[0]\},\\n\\nI noticed $\{leads[0].company\} might be dealing with $\{pain\}\\n\\nWe help teams fix that fast. Worth a $\{duration\}-min chat?\\n\\nBest,\\n$\{senderName\}, $\{senderCo\}`;
\fs24 \

\fs20 \}
\fs24 \

\fs20 await sleep(1600);
\fs24 \

\fs20 setDot(3,'done');setSub(3,`$\{leads.length\} emails sent via Gmail`);
\fs24 \

\fs20 showDetail('e3',emailText,'email');
\fs24 \

\fs20 await sleep(400);
\fs24 \
\

\fs20 setDot(4,'running');setSub(4,'Creating Google Calendar events...');
\fs24 \

\fs20 const now=new Date();
\fs24 \

\fs20 const bookedLeads=[];
\fs24 \

\fs20 const offsets=[3,5,8];
\fs24 \

\fs20 const times=['10:00 AM','11:00 AM','10:00 AM'];
\fs24 \

\fs20 for(let i=0;i<leads.length;i++)\{
\fs24 \

\fs20 const d=new Date(now);d.setDate(now.getDate()+offsets[i]);
\fs24 \

\fs20 const day=d.getDate();
\fs24 \

\fs20 const mo=d.toLocaleString('en-AU',\{month:'short'\});
\fs24 \

\fs20 const dow=d.toLocaleString('en-AU',\{weekday:'short'\});
\fs24 \

\fs20 leads[i].meetStr=`$\{dow\} $\{day\} $\{mo\} \'b7 $\{times[i]\}`;
\fs24 \

\fs20 leads[i].day=day;
\fs24 \

\fs20 leads[i].time=times[i].split(':')[0]+':'+times[i].split(':')[1].slice(0,2);
\fs24 \

\fs20 leads[i].first=leads[i].name.split(' ')[0];
\fs24 \

\fs20 bookedLeads.push(\{day,time:leads[i].time.replace(':00',''),first:leads[i].first\});
\fs24 \

\fs20 try\{
\fs24 \

\fs20 const ds=d.toISOString().split('T')[0];
\fs24 \

\fs20 const hr=parseInt(times[i])+i;
\fs24 \

\fs20 await callCalendar(`Create calendar event: "Discovery call with $\{leads[i].name\} ($\{leads[i].company\})" on $\{ds\} at $\{hr\}:00 for $\{duration\} minutes. Add description: $\{leads[i].email\}`);
\fs24 \

\fs20 \}catch(e)\{\}
\fs24 \

\fs20 \}
\fs24 \

\fs20 await sleep(1500);
\fs24 \

\fs20 setDot(4,'done');setSub(4,`$\{leads.length\} meetings booked`);
\fs24 \

\fs20 showDetail('e4',leads.map(l=>`$\{{\field{\*\fldinst{HYPERLINK "http://l.name/"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 l.name}}\} \'97 $\{l.meetStr\}`).join('\\n'));
\fs24 \

\fs20 renderCalendar(bookedLeads);
\fs24 \

\fs20 await sleep(400);
\fs24 \
\

\fs20 setDot(5,'running');setSub(5,'Sending confirmations...');
\fs24 \

\fs20 for(const l of leads)\{
\fs24 \

\fs20 try\{await callGmail(`Send confirmation to $\{l.email\}: Meeting with $\{senderName\} at $\{senderCo\} is confirmed for $\{l.meetStr\}. Duration: $\{duration\} mins. A calendar invite has been sent.`);\}catch(e)\{\}
\fs24 \

\fs20 \}
\fs24 \

\fs20 await sleep(1200);
\fs24 \

\fs20 setDot(5,'done');setSub(5,`$\{leads.length\} confirmations sent`);
\fs24 \

\fs20 showDetail('e5',leads.map(l=>`$\{{\field{\*\fldinst{HYPERLINK "http://l.name/"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 l.name}}\} <$\{l.email\}> \'97 confirmed`).join('\\n'));
\fs24 \
\

\fs20 document.getElementById('pipeline-badge').textContent='Complete';
\fs24 \

\fs20 document.getElementById('pipeline-badge').className='badge green';
\fs24 \
\

\fs20 document.getElementById('r-leads').textContent=leads.length;
\fs24 \

\fs20 document.getElementById('r-meetings').textContent=leads.length;
\fs24 \

\fs20 document.getElementById('success-sub').textContent=`LeadFlow found $\{leads.length\} leads in $\{industry\}, sent personalised outreach from $\{senderName\} at $\{senderCo\}, booked $\{leads.length\} meetings, and sent confirmations \'97 all automatically.`;
\fs24 \
\

\fs20 document.getElementById('leads-list').innerHTML=leads.map((l,i)=>`
\fs24 \

\fs20 <div class="lead-row">
\fs24 \

\fs20 <div class="av $\{avColors[i]\}">$\{l.name.split(' ').map(w=>w[0]).join('').slice(0,2)\}</div>
\fs24 \

\fs20 <div style="flex:1">
\fs24 \

\fs20 <div class="lead-name">$\{{\field{\*\fldinst{HYPERLINK "http://l.name/"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 l.name}}\}</div>
\fs24 \

\fs20 <div class="lead-meta">$\{l.title\} \'b7 $\{l.company\} \'b7 $\{l.email\}</div>
\fs24 \

\fs20 </div>
\fs24 \

\fs20 <span class="lead-meet">$\{l.meetStr\}</span>
\fs24 \

\fs20 </div>`).join('');
\fs24 \
\

\fs20 document.getElementById('results-section').style.display='block';
\fs24 \

\fs20 await sleep(100);
\fs24 \

\fs20 document.getElementById('results-section').scrollIntoView(\{behavior:'smooth',block:'start'\});
\fs24 \

\fs20 document.getElementById('runBtn').disabled=false;
\fs24 \

\fs20 \}
\fs24 \
\

\fs20 function resetAll()\{
\fs24 \

\fs20 document.getElementById('pipeline-section').style.display='none';
\fs24 \

\fs20 document.getElementById('results-section').style.display='none';
\fs24 \

\fs20 for(let i=1;i<=5;i++)\{setDot(i,'idle');setSub(i,'Waiting...');const e=document.getElementById('e'+i);e.textContent='';e.className='pdetail';\}
\fs24 \

\fs20 document.getElementById('pipeline-badge').textContent='In progress';
\fs24 \

\fs20 document.getElementById('pipeline-badge').className='badge blue';
\fs24 \

\fs20 document.getElementById('runBtn').disabled=false;
\fs24 \

\fs20 window.scrollTo(\{top:0,behavior:'smooth'\});
\fs24 \

\fs20 \}
\fs24 \

\fs20 </script>
\fs24 \

\fs20 <style>@keyframes spin2\{to\{transform:rotate(360deg)\}\}</style>
\fs24 \

\fs20 </body>
\fs24 \

\fs20 </html>}